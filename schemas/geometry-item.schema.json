{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.example/schemas/geometry-item.schema.json",
  "title": "Geometry Item",
  "type": "object",
  "required": ["figure_id", "asset_id", "relations", "review_state"],
  "properties": {
    "figure_id": {"type": "string"},
    "asset_id": {"type": "string"},
    "associated_item_id": {"type": "string"},
    "points": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "segments": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "entities", "evidence", "confidence", "review_state"],
        "properties": {
          "type": {"type": "string"},
          "entities": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "evidence": {
            "enum": [
              "problem_text",
              "diagram_mark",
              "problem_text_and_diagram_mark",
              "visual_inference",
              "unknown"
            ]
          },
          "source_reference": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "review_state": {"enum": ["unreviewed", "confirmed", "corrected", "rejected"]}
        },
        "additionalProperties": true
      }
    },
    "visual_observations": {"type": "array", "items": {"type": "string"}},
    "review_state": {"enum": ["unreviewed", "confirmed", "corrected", "rejected"]}
  },
  "additionalProperties": true
}
